rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------
    // HELPERS
    // -------------------------

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUser(userId) {
      return get(/databases/$(database)/documents/userProfiles/$(userId)).data;
    }

    function isAdmin() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid))
        && getUser(request.auth.uid).isAdmin == true;
    }

    function isSupport() {
      return isAdmin() ||
        (isAuthenticated()
        && exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid))
        && getUser(request.auth.uid).isSupport == true);
    }

    function isChatMember(chatData) {
      return isAuthenticated() && request.auth.uid in chatData.participants;
    }

    // -------------------------
    // USER PROFILES
    // -------------------------

    match /userProfiles/{userId} {

      // Allow reading if authenticated or if checking for existence
      allow read: if isAuthenticated();

      allow create: if isOwner(userId);

      allow update: if isOwner(userId) || isAdmin();

      allow delete: if isAdmin();

      // Transactions (coins history)
      match /transactions/{transactionId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isAdmin();
      }

      // Block list
      match /blockedUsers/{blockedId} {
        allow read, write: if isOwner(userId);
      }

      // Visitors
      match /visitors/{visitorId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isAuthenticated();
      }
    }

    // -------------------------
    // CHATS (SECURED)
    // -------------------------

    match /chats/{chatId} {

      // Allow read if user is participant OR if doc doesn't exist yet (to check existence safely)
      allow read: if isAuthenticated()
        && (resource == null || isChatMember(resource.data));

      allow create: if isAuthenticated()
        && request.resource.data.participants.size() == 2
        && request.auth.uid in request.resource.data.participants;

      allow update: if isAuthenticated()
        && isChatMember(resource.data)
        && request.resource.data.participants == resource.data.participants;

      allow delete: if isAuthenticated()
        && isChatMember(resource.data);

      match /messages/{messageId} {

        allow read: if isAuthenticated()
          && isChatMember(
            get(/databases/$(database)/documents/chats/$(chatId)).data
          );

        allow create: if isAuthenticated()
          && isChatMember(
            get(/databases/$(database)/documents/chats/$(chatId)).data
          );

        allow update, delete: if false;
      }
    }

    // -------------------------
    // CALLS (SECURED)
    // -------------------------

    match /calls/{callId} {
      allow read, write: if isAuthenticated()
        && request.auth.uid in resource.data.participants;
    }

    // -------------------------
    // REPORTS / MODERATION
    // -------------------------

    match /reports/{reportId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isSupport();
    }

    // -------------------------
    // AGENCIES (LOCKED DOWN)
    // -------------------------

    match /agencies/{agencyId} {
      allow read: if isAuthenticated();

      allow write: if isAuthenticated() && isAdmin();

      match /{allPaths=**} {
        allow read, write: if isAdmin();
      }
    }

    // -------------------------
    // PARTY ROOMS (LOCKED)
    // -------------------------

    match /partyRooms/{roomId} {
      allow read: if isAuthenticated();

      allow write: if isAuthenticated()
        && request.auth.uid == resource.data.hostId;

      match /{allPaths=**} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated()
          && request.auth.uid == resource.data.hostId;
      }
    }

    // -------------------------
    // PAYMENTS (SECURED)
    // -------------------------

    match /pendingPayments/{orderId} {
      allow read: if isAuthenticated();

      allow write: if isAdmin(); // ONLY backend should confirm payments
    }

    // -------------------------
    // DEFAULT LOCKDOWN (IMPORTANT FIX)
    // -------------------------

    match /{document=**} {
      allow read, write: if false;
    }
  }
}