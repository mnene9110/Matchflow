
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid)) &&
        getUserData().isAdmin == true;
    }

    function isSupport() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid)) &&
         getUserData().isSupport == true) || 
        isAdmin()
      );
    }

    // --- User Profiles ---

    match /userProfiles/{userId} {
      allow read: if isAuthenticated();
      
      // Allow creation during onboarding
      allow create: if isAuthenticated() && request.auth.uid == userId;
      
      // Protect sensitive fields from self-update
      allow update: if isAuthenticated() && (
        isAdmin() || 
        // Users can update their own non-sensitive fields
        (request.auth.uid == userId && 
         !request.resource.data.diff(resource.data).affectedKeys()
           .hasAny(['isAdmin', 'isSupport', 'isCoinseller', 'isAgent', 'isPartyAdmin', 'coinBalance', 'diamondBalance', 'numericId'])) ||
        // Allow updates to state/handshake fields
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['isOnline', 'lastActiveAt', 'incomingCallId', 'inCall', 'lastCheckInDate', 'checkInStreak', 'boostedUntil', 'visitorsUnlocked', 'agencyJoinStatus', 'memberOfAgencyId', 'agencyId'])
      );
      
      match /transactions/{transactionId} {
        allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
        allow write: if isAuthenticated() && (isAdmin() || getUserData().isCoinseller == true);
      }
      
      match /blockedUsers/{blockedId} {
        allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      }

      match /visitors/{visitorId} {
        allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
        allow write: if isAuthenticated();
      }
    }

    // --- Private Chats ---

    match /chats/{chatId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants;
      allow update: if isAuthenticated() && (
        request.auth.uid in resource.data.participants || 
        request.auth.uid in request.resource.data.participants
      );
      
      match /messages/{messageId} {
        allow read: if isAuthenticated() && 
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isAuthenticated();
      }
    }

    // --- Calls & Signaling ---

    match /calls/{callId} {
      allow read, write: if isAuthenticated();
    }

    // --- Safety & Support ---

    match /reports/{reportId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isSupport();
    }

    // --- Agencies ---

    match /agencies/{agencyId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
      
      match /{allPaths=**} {
        allow read, write: if isAuthenticated();
      }
    }

    // --- Party Rooms ---

    match /partyRooms/{roomId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
      
      match /{allPaths=**} {
        allow read, write: if isAuthenticated();
      }
    }

    // --- Internal Payment Tracking ---

    match /pendingPayments/{orderId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // --- Global List Access ---

    match /{path=**} {
      allow list: if isAuthenticated();
    }
  }
}
