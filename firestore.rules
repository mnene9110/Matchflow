rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to check if user is accessing their own document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Profiles security
    match /userProfiles/{userId} {
      // Anyone logged in can read profiles for discovery
      allow read: if isAuthenticated();
      
      // Only the owner can update their profile.
      // SECURITY: Prevent users from self-assigning sensitive roles (Admin, Support, Coinseller)
      allow create: if isOwner(userId) && (
        !request.resource.data.hasAny(['isAdmin', 'isCoinseller', 'isSupport']) || 
        (request.resource.data.get('isAdmin', false) == false && 
         request.resource.data.get('isCoinseller', false) == false && 
         request.resource.data.get('isSupport', false) == false)
      );

      allow update: if isOwner(userId) && (
        // Prevent changing existing sensitive flags
        request.resource.data.isAdmin == resource.data.isAdmin &&
        request.resource.data.isCoinseller == resource.data.isCoinseller &&
        request.resource.data.isSupport == resource.data.isSupport
      );

      // Secure sub-collections
      match /transactions/{transactionId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
      }

      match /blockedUsers/{blockedId} {
        // A user being blocked can 'get' their own specific document in another user's blocked list.
        // This allows the app to verify if the current user is restricted by the person they are chatting with.
        allow get: if isAuthenticated() && (request.auth.uid == userId || request.auth.uid == blockedId);
        allow list: if isOwner(userId);
        allow write: if isOwner(userId);
      }
    }

    // Call signaling security
    match /calls/{chatId} {
      // chatId is formatted as "uid1_uid2"
      allow read, write: if isAuthenticated() && (
        chatId.split('_')[0] == request.auth.uid ||
        chatId.split('_')[1] == request.auth.uid
      );
    }

    // Default deny for all other paths
    match /{path=**} {
      allow read, write: if false;
    }
  }
}