
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.isAdmin == true;
    }

    function isSupport() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.isSupport == true) || 
        isAdmin()
      );
    }

    match /userProfiles/{userId} {
      allow read: if isAuthenticated();
      
      // Allow creation during onboarding
      allow create: if isAuthenticated() && request.auth.uid == userId;
      
      // Protect sensitive fields from self-update
      allow update: if isAuthenticated() && (
        // Admins can update everything
        isAdmin() || 
        
        // Users can update their own non-sensitive fields
        (request.auth.uid == userId && 
         !request.resource.data.diff(resource.data).affectedKeys()
           .hasAny(['isAdmin', 'isSupport', 'isCoinseller', 'isAgent', 'isPartyAdmin', 'coinBalance', 'diamondBalance', 'numericId'])) ||
        
        // Anyone can update call handshake and presence fields
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['isOnline', 'lastActiveAt', 'incomingCallId', 'inCall'])
      );
      
      match /transactions/{transactionId} {
        allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
        // Only Admins or Coinsellers (via code logic) should be writing to transactions
        allow write: if isAuthenticated() && (isAdmin() || 
          get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.isCoinseller == true);
      }
      
      match /blockedUsers/{blockedId} {
        allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      }
    }

    match /chats/{chatId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants;
      allow update: if isAuthenticated() && (
        request.auth.uid in resource.data.participants || 
        request.auth.uid in request.resource.data.participants
      );
      
      match /messages/{messageId} {
        allow read: if isAuthenticated() && 
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isAuthenticated();
      }
    }

    match /calls/{callId} {
      allow read, write: if isAuthenticated();
    }

    match /reports/{reportId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isSupport();
    }

    match /agencies/{agencyId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
      
      match /{allPaths=**} {
        allow read, write: if isAuthenticated();
      }
    }

    match /partyRooms/{roomId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
      
      match /{allPaths=**} {
        allow read, write: if isAuthenticated();
      }
    }

    match /{path=**} {
      allow list: if isAuthenticated();
    }
  }
}
