rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * MatchFlow Security Rules
     * 
     * Core Philosophy:
     * This ruleset enforces a strict user-ownership model for personal data and a shared-access model 
     * for social interactions (Matches, Chats). It relies heavily on path-based authorization and 
     * data denormalization to ensure performant, atomic security checks without requiring 
     * cross-document lookups (get() calls).
     * 
     * Data Structure:
     * - /userProfiles/{userId}: Public-facing profiles used for match discovery.
     * - /users/{userId}/...: Private user-siloed data including coin balances, transactions, and likes.
     * - /chatSessions/{chatSessionId}: Shared conversation threads between matched users.
     * 
     * Key Security Decisions:
     * 1. Authorization Independence: Critical IDs (like participant UIDs) are denormalized into 
     *    documents (e.g., user1Id, user2Id) to allow rules to validate access locally.
     *    2. Structural Segregation: Incoming vs. Outgoing likes are stored in separate subcollections 
     *    to simplify "list" operations and provide clear ownership boundaries.
     * 3. Prototyping Flexibility: Rules enforce WHO can write but do not strictly validate 
     *    the non-relational data schema (e.g., string lengths or optional fields).
     */

    // --- Helper Functions ---

    /** Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the authenticated user matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** Checks if the user is one of the two participants in a shared document. */
    function isParticipant(data) {
      return isSignedIn() && (request.auth.uid == data.user1Id || request.auth.uid == data.user2Id);
    }

    /** Validates that the document exists before allowing an update or delete. */
    function exists(res) {
      return res != null;
    }

    // --- Collection Rules ---

    /**
     * @description Rules for user profiles. Publicly readable by all users for discovery, writable only by owner.
     * @path /userProfiles/{userId}
     * @allow (get/list) if signed in. (create) if auth.uid matches userId.
     * @deny (write) if trying to modify another user's profile.
     * @principle Enforces path-based ownership for writes and public read for discovery.
     */
    match /userProfiles/{userId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId) && exists(resource) && request.resource.data.id == resource.data.id;
      allow delete: if isOwner(userId) && exists(resource);
    }

    /**
     * @description Private coin account balance. Strictly owner-access only.
     * @path /users/{userId}/coinAccount/{accountId}
     * @allow (read/write) if user is the path owner.
     * @deny (any) if uid does not match the parent {userId}.
     * @principle Restricts access to a user's own data tree.
     */
    match /users/{userId}/coinAccount/{accountId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isOwner(userId) && exists(resource) && request.resource.data.userId == resource.data.userId;
      allow delete: if isOwner(userId) && exists(resource);

      /**
       * @description Historical transaction records for the coin account.
       * @path /users/{userId}/coinAccount/transactions/{transactionId}
       */
      match /transactions/{transactionId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update, delete: if false; // Transactions are immutable audit logs
      }
    }

    /**
     * @description Records likes sent by the user.
     * @path /users/{userId}/outgoingLikes/{likeId}
     * @allow (create/list) if owner of the path.
     * @principle Path-based ownership for outgoing actions.
     */
    match /users/{userId}/outgoingLikes/{likeId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.likerId == userId;
      allow update: if isOwner(userId) && exists(resource) && request.resource.data.likerId == resource.data.likerId;
      allow delete: if isOwner(userId) && exists(resource);
    }

    /**
     * @description Records likes received by the user.
     * @path /users/{userId}/incomingLikes/{likeId}
     * @allow (get/list) if owner of the path.
     * @principle Restricts visibility of incoming likes to the recipient.
     */
    match /users/{userId}/incomingLikes/{likeId} {
      allow get, list: if isOwner(userId);
      allow create, update, delete: if false; // System-managed or triggered via outgoingLikes logic
    }

    /**
     * @description User-specific view of mutual matches.
     * @path /users/{userId}/matches/{matchId}
     * @allow (get/list) if owner of the path.
     * @principle Provides secure user-centric list of matches.
     */
    match /users/{userId}/matches/{matchId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && (request.resource.data.user1Id == userId || request.resource.data.user2Id == userId);
      allow update: if isOwner(userId) && exists(resource);
      allow delete: if isOwner(userId) && exists(resource);
    }

    /**
     * @description Shared chat sessions between two matched users.
     * @path /chatSessions/{chatSessionId}
     * @allow (read) if uid is user1Id or user2Id.
     * @deny (write) if user is not a participant.
     * @principle Shared access via denormalized participant IDs.
     */
    match /chatSessions/{chatSessionId} {
      allow get, list: if isParticipant(resource.data);
      allow create: if isParticipant(request.resource.data);
      allow update: if isParticipant(resource.data) && exists(resource);
      allow delete: if isParticipant(resource.data) && exists(resource);

      /**
       * @description Messages within a chat session.
       * @path /chatSessions/{chatSessionId}/messages/{messageId}
       * @allow (create) if user is the sender and a participant.
       */
      match /messages/{messageId} {
        allow get, list: if isParticipant(get(/databases/$(database)/documents/chatSessions/$(chatSessionId)).data);
        allow create: if isParticipant(get(/databases/$(database)/documents/chatSessions/$(chatSessionId)).data) 
                      && request.resource.data.senderId == request.auth.uid;
        allow update: if isParticipant(resource.data) && exists(resource);
        allow delete: if isParticipant(resource.data) && exists(resource);
      }

      /**
       * @description Video call records linked to a chat session.
       * @path /chatSessions/{chatSessionId}/videoCalls/{videoCallId}
       */
      match /videoCalls/{videoCallId} {
        allow get, list: if isParticipant(get(/databases/$(database)/documents/chatSessions/$(chatSessionId)).data);
        allow create: if isParticipant(get(/databases/$(database)/documents/chatSessions/$(chatSessionId)).data)
                      && request.resource.data.callerId == request.auth.uid;
        allow update: if isParticipant(resource.data) && exists(resource);
        allow delete: if isParticipant(resource.data) && exists(resource);
      }
    }
  }
}