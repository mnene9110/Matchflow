
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to check if user is accessing their own document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Profiles security
    match /userProfiles/{userId} {
      // Anyone logged in can read profiles for discovery
      allow read: if isAuthenticated();
      
      // Only the owner can update their profile.
      allow write: if isOwner(userId);

      // Secure sub-collections
      match /transactions/{transactionId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
      }

      match /blockedUsers/{blockedId} {
        // A user being blocked can 'get' their own specific document in another user's blocked list.
        // This allows the app to verify if the current user is restricted by the person they are chatting with.
        allow get: if isAuthenticated() && (request.auth.uid == userId || request.auth.uid == blockedId);
        allow list: if isOwner(userId);
        allow write: if isOwner(userId);
      }
    }

    // Call signaling security
    match /calls/{chatId} {
      allow read, write: if isAuthenticated() && (
        chatId.split('_')[0] == request.auth.uid ||
        chatId.split('_')[1] == request.auth.uid
      );
    }
  }
}
