rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.isAdmin == true;
    }

    function isSupport() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.isSupport == true || 
        isAdmin()
      );
    }

    // User Profile Rules
    match /userProfiles/{userId} {
      // Authenticated users can browse profiles
      allow read: if isAuthenticated();
      
      // Users can edit their own profile, or Admins can edit any profile
      allow write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      
      // Sub-collections: Only the owner or Admins can access private data
      match /transactions/{transactionId} {
        allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      }
      
      match /blockedUsers/{blockedId} {
        allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      }
    }

    // Messaging Rules
    match /chats/{chatId} {
      // Must be a participant to read or update chat metadata
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants;
      allow update: if isAuthenticated() && request.auth.uid in resource.data.participants;
      
      match /messages/{messageId} {
        // Access restricted to chat participants
        allow read, write: if isAuthenticated() && 
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }

    // Calling Rules (Signaling)
    match /calls/{callId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.callerId || 
        request.auth.uid == resource.data.receiverId
      );
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.callerId;
      allow update, delete: if isAuthenticated() && (
        request.auth.uid == resource.data.callerId || 
        request.auth.uid == resource.data.receiverId ||
        isAdmin()
      );
    }

    // Agency Rules
    match /agencies/{agencyId} {
      allow read: if isAuthenticated();
      // Allow creation if it doesn't exist, or modification by the agent/admin
      allow write: if isAuthenticated() && (
        !exists(/databases/$(database)/documents/agencies/$(agencyId)) || 
        request.auth.uid == resource.data.agentId || 
        isAdmin()
      );

      match /requests/{userId} {
        allow read, write: if isAuthenticated();
      }

      match /members/{userId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated();
      }

      match /withdrawals/{requestId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated();
      }
    }

    // Party Room Rules
    match /partyRooms/{roomId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (
        !exists(/databases/$(database)/documents/partyRooms/$(roomId)) || 
        request.auth.uid == resource.data.hostId || 
        isAdmin()
      );

      match /participants/{userId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      }

      match /messages/{msgId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated();
      }

      match /seats/{index} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated();
      }
    }

    // Reports: Any user can report another, but only staff should handle them
    match /reports/{reportId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isSupport();
    }

    // Global list permissions for queries (e.g., Discover feed)
    match /{path=**} {
      allow list: if isAuthenticated();
    }
  }
}