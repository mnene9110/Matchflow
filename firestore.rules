
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------
    // HELPERS
    // -------------------------

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUser(userId) {
      return get(/databases/$(database)/documents/userProfiles/$(userId)).data;
    }

    function isAdmin() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid))
        && getUser(request.auth.uid).isAdmin == true;
    }

    function isSupport() {
      return isAdmin() ||
        (isAuthenticated()
        && exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid))
        && getUser(request.auth.uid).isSupport == true);
    }

    function isCoinseller() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid))
        && getUser(request.auth.uid).isCoinseller == true;
    }

    function isChatMember(chatData) {
      return isAuthenticated() && request.auth.uid in chatData.participants;
    }

    // -------------------------
    // USER PROFILES
    // -------------------------

    match /userProfiles/{userId} {

      allow read: if isAuthenticated();

      allow create: if isOwner(userId);

      allow update: if isOwner(userId) || isAdmin() || isCoinseller() || (
        isAuthenticated() && (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['diamondBalance', 'updatedAt']) ||
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isOnline', 'lastActiveAt', 'incomingCallId', 'inCall']) ||
          request.resource.data.diff(resource.data).affectedKeys().hasAny(['coinBalance'])
        )
      );

      allow delete: if isOwner(userId) && !isAdmin();

      match /transactions/{transactionId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId) || isAdmin() || isCoinseller() || (
          isAuthenticated() && request.resource.data.type in ['gift_received', 'diamond_received', 'gift_sent']
        );
      }

      match /blockedUsers/{blockedId} {
        allow read, write: if isOwner(userId);
      }

      match /visitors/{visitorId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isAuthenticated();
      }
    }

    // -------------------------
    // CHATS (SECURED)
    // -------------------------

    match /chats/{chatId} {
      allow read: if isAuthenticated()
        && (resource == null || isChatMember(resource.data));

      allow create: if isAuthenticated()
        && request.resource.data.participants.size() == 2
        && request.auth.uid in request.resource.data.participants;

      allow update: if isAuthenticated()
        && isChatMember(resource.data)
        && request.resource.data.participants == resource.data.participants;

      allow delete: if isAuthenticated()
        && isChatMember(resource.data);

      match /messages/{messageId} {
        allow read: if isAuthenticated()
          && (
            !exists(/databases/$(database)/documents/chats/$(chatId)) ||
            isChatMember(get(/databases/$(database)/documents/chats/$(chatId)).data)
          );

        allow create: if isAuthenticated()
          && isChatMember(
            get(/databases/$(database)/documents/chats/$(chatId)).data
          );

        allow update, delete: if false;
      }
    }

    // -------------------------
    // CALLS (SECURED)
    // -------------------------

    match /calls/{callId} {
      allow read, update, delete: if isAuthenticated()
        && (resource == null || request.auth.uid in resource.data.participants);
      
      allow create: if isAuthenticated()
        && request.auth.uid in request.resource.data.participants;
    }

    // -------------------------
    // REPORTS / MODERATION
    // -------------------------

    match /reports/{reportId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isSupport();
    }

    // -------------------------
    // AGENCIES (LOCKED DOWN)
    // -------------------------

    match /agencies/{agencyId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isAdmin();

      match /{allPaths=**} {
        allow read, write: if isAdmin();
      }
    }

    // -------------------------
    // PAYMENTS (SECURED)
    // -------------------------

    match /pendingPayments/{orderId} {
      allow read, create: if isAuthenticated();
      allow update: if isAdmin(); 
    }

    // -------------------------
    // DEFAULT LOCKDOWN
    // -------------------------

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
