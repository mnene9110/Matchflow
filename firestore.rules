rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if the requesting user is an Admin
    function isAdmin() {
      return request.auth != null && get(/databases/(default)/documents/userProfiles/$(request.auth.uid)).data.isAdmin == true;
    }

    // Helper to check if the requesting user is Support staff
    function isSupport() {
      return request.auth != null && (get(/databases/(default)/documents/userProfiles/$(request.auth.uid)).data.isSupport == true || isAdmin());
    }

    // User Profile Rules
    match /userProfiles/{userId} {
      // Authenticated users can browse profiles
      allow read: if request.auth != null;
      
      // Users can edit their own profile, or Admins can edit any profile
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
      
      // Sub-collections: Only the owner or Admins can access private data
      match /transactions/{transactionId} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
      }
      
      match /blockedUsers/{blockedId} {
        // Users manage their own block lists. Admins can view them for safety checks.
        allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
      }
    }

    // Reports: Any user can report another, but only staff should handle them
    match /reports/{reportId} {
      allow create: if request.auth != null;
      allow read, update, delete: if isSupport();
    }

    // Global list permissions for queries (e.g., Discover feed)
    match /{path=**} {
      allow list: if request.auth != null;
    }
  }
}