{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile and wallet information.",
      "properties": {
        "id": { "type": "string" },
        "numericId": { "type": "number" },
        "authProviderId": { "type": "string" },
        "username": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "bio": { "type": "string" },
        "dateOfBirth": { "type": "string", "format": "date" },
        "gender": { "type": "string" },
        "preferredGenders": {
          "type": "array",
          "items": { "type": "string" }
        },
        "location": { "type": "string" },
        "relationshipGoal": { "type": "string" },
        "education": { "type": "string" },
        "horoscope": { "type": "string" },
        "interests": {
          "type": "array",
          "items": { "type": "string" }
        },
        "profilePhotoUrls": {
          "type": "array",
          "items": { "type": "string" }
        },
        "coinBalance": { "type": "number" },
        "lastCheckInDate": { "type": "string", "format": "date" },
        "checkInStreak": { "type": "number" },
        "isVerified": { "type": "boolean" },
        "isAdmin": { "type": "boolean" },
        "isCoinseller": { "type": "boolean" },
        "isSupport": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "lastActiveAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "authProviderId", "username", "dateOfBirth", "gender", "createdAt", "coinBalance"]
    },
    "CoinTransaction": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "CoinTransaction",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "amount": { "type": "number" },
        "transactionDate": { "type": "string", "format": "date-time" },
        "description": { "type": "string" },
        "orderTrackingId": { "type": "string" }
      },
      "required": ["id", "type", "amount", "transactionDate"]
    },
    "CallSession": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "CallSession",
      "type": "object",
      "properties": {
        "callerId": { "type": "string" },
        "receiverId": { "type": "string" },
        "status": { "type": "string", "enum": ["ringing", "accepted"] },
        "callType": { "type": "string", "enum": ["video", "audio"] },
        "timestamp": { "type": "number" },
        "callerName": { "type": "string" }
      }
    },
    "Report": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Report",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "reporterId": { "type": "string" },
        "reportedUserId": { "type": "string" },
        "details": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "reviewed"] }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/userProfiles/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/entities/UserProfile" }
        }
      },
      {
        "path": "/userProfiles/{userId}/transactions/{transactionId}",
        "definition": {
          "entityName": "CoinTransaction",
          "schema": { "$ref": "#/entities/CoinTransaction" }
        }
      },
      {
        "path": "/calls/{chatId}",
        "definition": {
          "entityName": "CallSession",
          "schema": { "$ref": "#/entities/CallSession" }
        }
      },
      {
        "path": "/reports/{reportId}",
        "definition": {
          "entityName": "Report",
          "schema": { "$ref": "#/entities/Report" }
        }
      }
    ]
  }
}