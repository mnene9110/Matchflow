{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('isAdmin').val() === true || root.child('users').child(auth.uid).child('isCoinseller').val() === true)",
        "incomingCallId": {
          ".write": "auth != null"
        },
        "presence": {
          ".write": "auth != null && auth.uid === $uid"
        },
        "chats": {
          "$otherId": {
            ".write": "auth != null && $otherId === auth.uid",
            ".read": "auth != null && (auth.uid === $uid || $otherId === auth.uid)"
          }
        }
      }
    },
    "chats": {
      "$chatId": {
        ".read": "auth != null && $chatId.contains(auth.uid)",
        ".write": "auth != null && $chatId.contains(auth.uid)"
      }
    },
    "calls": {
      "$chatId": {
        ".read": "auth != null && $chatId.contains(auth.uid)",
        ".write": "auth != null && $chatId.contains(auth.uid)"
      }
    },
    "partyRooms": {
      ".read": "auth != null",
      "$roomId": {
        ".write": "auth != null && (!data.exists() || data.child('hostId').val() === auth.uid || root.child('users').child(auth.uid).child('isAdmin').val() === true)",
        "participants": {
          "$userId": {
            ".write": "auth != null && $userId === auth.uid"
          }
        }
      }
    },
    "agencies": {
      ".read": "auth != null",
      "$agencyId": {
        ".write": "auth != null && (!data.exists() || data.child('agentId').val() === auth.uid || root.child('users').child(auth.uid).child('isAdmin').val() === true)"
      }
    },
    "agencyRequests": {
      "$agencyId": {
        ".read": "auth != null && (root.child('agencies').child($agencyId).child('agentId').val() === auth.uid || root.child('users').child(auth.uid).child('isAdmin').val() === true)",
        "$userId": {
          ".write": "auth != null && (auth.uid === $userId || root.child('agencies').child($agencyId).child('agentId').val() === auth.uid || root.child('users').child(auth.uid).child('isAdmin').val() === true)"
        }
      }
    },
    "agencyMembers": {
      "$agencyId": {
        ".read": "auth != null",
        "$userId": {
          ".write": "auth != null && (auth.uid === $userId || root.child('agencies').child($agencyId).child('agentId').val() === auth.uid || root.child('users').child(auth.uid).child('isAdmin').val() === true)"
        }
      }
    },
    "agencyWithdrawals": {
      "$agencyId": {
        ".read": "auth != null && (root.child('agencies').child($agencyId).child('agentId').val() === auth.uid || root.child('users').child(auth.uid).child('isAdmin').val() === true)",
        "$requestId": {
          ".write": "auth != null"
        }
      }
    }
  }
}