
{
  "rules": {
    "users": {
      "$uid": {
        "presence": {
          ".read": "auth != null",
          ".write": "auth.uid === $uid",
          "online": { ".validate": "newData.isBoolean()" },
          "lastSeen": { ".validate": "newData.isNumber()" }
        },
        "chats": {
          ".read": "auth.uid === $uid",
          "$otherId": {
            // Sender can increment unread count, owner can clear it
            ".write": "auth.uid === $uid || auth.uid === $otherId",
            "unreadCount": {
               ".validate": "newData.isNumber() && newData >= 0"
            }
          }
        }
      }
    },
    "chats": {
      "$chatId": {
        // ChatId must contain the user's UID to allow access
        ".read": "auth != null && $chatId.contains(auth.uid)",
        ".write": "auth != null && $chatId.contains(auth.uid)",
        "messages": {
          "$msgId": {
            ".validate": "newData.hasChildren(['messageText', 'senderId', 'sentAt'])",
            "senderId": { ".validate": "newData.val() === auth.uid" },
            "sentAt": { ".validate": "newData.isNumber()" }
          }
        }
      }
    }
  }
}
